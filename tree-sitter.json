    "license": "MIT",
    "description": "functional C",
    "authors": [
      {
        "name": "kevin0x0",
        "email": "kevin0x00@163.com"
      }
    ],
    "links": {
      "repository": "https://github.com/kevin0x0/tree-sitter-fc"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}