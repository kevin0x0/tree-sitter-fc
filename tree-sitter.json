{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "fc",
      "camelcase": "Fc",
      "title": "Fc",
      "scope": "source.fc",
      "file-types": [
        "fc"
      ],
      "injection-regex": "^fc$",
      "class-name": "TreeSitterFc"
    }
  ],
  "metadata": {
